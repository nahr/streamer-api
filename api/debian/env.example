# Table TV configuration - copy to .env and customize
# cp /etc/table-tv/env.example /etc/table-tv/.env

PORT=8080
SQLITE_PATH=/var/lib/table-tv/table-tv.db

# Optional: fixed token for RTMP pipeline
# STREAM_TOKEN=your-secret-token

# Optional: Facebook integration
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# BASE_URL=http://localhost:80

# Auth0 (required for login)
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-spa-client-id
# AUTH0_AUDIENCE=https://your-api-identifier
# AUTH0_SKIP_AUDIENCE=true
# AUTH0_CONNECTION=facebook

# MediaMTX (for RTSP cameras)
# MEDIAMTX_API_URL=http://127.0.0.1:9997

# Facebook RTMPS via stunnel
# USE_STUNNEL_FOR_RTMPS=1
