# Table TV configuration - copy to .env and customize
PORT=80
POLODB_PATH=data/table-tv.db

# Camera index (0 = first device, 1 = second, etc.). Use 1 for USB webcam when internal camera is 0.
# CAMERA_INDEX=1

# Optional: Facebook integration
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# BASE_URL=http://localhost:80

# When running UI dev server (npm run dev) with API in Docker, set:
# VITE_API_TARGET=http://localhost:80

# Auth0 (required for login) - same vars for UI and API
# Create an Auth0 Application (SPA) and an API in the Auth0 dashboard.
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=your-spa-client-id     # From Auth0 SPA Application
# AUTH0_AUDIENCE=https://your-api-identifier  # API identifier from Auth0
# Optional: if localhost causes 403, use 127.0.0.1 and access app at http://127.0.0.1:5173
# AUTH0_REDIRECT_URI=http://127.0.0.1:5173
# If /authorize returns 403, use ID token instead of access token:
# AUTH0_SKIP_AUDIENCE=true
# Skip Auth0 method selection and go straight to a connection (e.g. facebook):
# AUTH0_CONNECTION=facebook
